rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /indicators/{indicatorId} {
      allow read: if true;
      match /datapoints/{periodId} {
        allow read: if true;
        match /versions/{versionId} {
          allow read: if true;
        }
      }
    }
    match /sources/{sourceId} {
      allow read: if true;
    }
    // ingestion_logs: no public access
    // All writes: admin SDK only (server-side)
  }
}
